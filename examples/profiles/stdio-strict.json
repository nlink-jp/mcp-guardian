{
  "name": "stdio-strict",
  "upstream": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/user/projects"]
  },
  "governance": {
    "enforcement": "strict",
    "schema": "strict",
    "maxCalls": 50,
    "timeout": 60000
  },
  "mask": [
    "delete_*",
    "execute_*"
  ],
  "stateDir": ".governance/filesystem"
}
